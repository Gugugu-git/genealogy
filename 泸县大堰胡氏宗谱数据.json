  "preface": {
    "content": "盖闻水有源，故其流不穷；木有根，故其生不断。家之有谱，犹国之有史，所以纪世系、辨昭穆、别亲疏、承祖德也。吾族本支，虽非显达，然亲族敦睦，患难相扶。今枝繁叶茂，丁口日增，恐年深日久，辈分淆乱，长幼无序。故重修族谱，以定尊卑，明次序，垂示后人。愿我族人，敬宗收族，敦伦睦友，守礼崇义，绵延家声，是所厚望焉。",
    "date": "时公元二〇二六年岁次丙午孟春吉旦。",
    "author": "合族修谱人 谨识"
  },
  "rules": [
    { "id": "rule_1", "number": "一", "content": "本谱以公讳继相为始祖，世代相承，依次序列，不乱尊卑。" },
    { "id": "rule_2", "number": "二", "content": "谱中书名，男子书名讳，妇人书配，女子书适。" },
    { "id": "rule_3", "number": "三", "content": "生卒年月、坟茔所在，有则书，无则阙，务求真实。" },
    { "id": "rule_4", "number": "四", "content": "族中子弟，无论贵贱贤愚，一体入谱，以昭一体之义。" },
    { "id": "rule_5", "number": "五", "content": "继嗣、迁徙、功名、善行，皆为备书，以励后人。" },
    { "id": "rule_6", "number": "六", "content": "本谱纪年，近代统用公元，附干支，以明时序。" },
    { "id": "rule_7", "number": "七", "content": "世系以五服为亲，高祖以下五世亲尽，为出服。" }
  ],
  "familyRules": {
    "content": "暂无"
  },
  "generation": {
    "poem": "自天承开继先贤\n清白传家世代延\n立意公平光斗宿\n存心正直昭乾元\n从今次第永依祖\n昌大余支定万年",
